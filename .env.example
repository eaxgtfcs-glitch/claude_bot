# Telegram Bot Token (от BotFather)
BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key — нужен ТОЛЬКО если используешь Вариант B (API ключ)
# Если используешь подписку claude.ai — эту строку убери или оставь пустой
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Твой Telegram user ID (через @userinfobot)
# Несколько через запятую: 123456789,987654321
ALLOWED_USER_IDS=123456789

# Рабочая директория (можно менять через /cd)
WORKSPACE_DIR=./workspace

# Таймаут задачи в секундах
CLAUDE_TIMEOUT=300
